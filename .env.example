# SwitchOps — Environment Variables
# Copy this file to .env and fill in your values

# Salesforce Connected App Consumer Key (Client ID)
VITE_SF_CLIENT_ID=your_connected_app_consumer_key_here

# OAuth Redirect URI (must match the Connected App callback URL)
VITE_SF_REDIRECT_URI=http://localhost:5173/callback

# Auth Proxy URL (the backend proxy that handles token exchange and API calls)
VITE_SF_AUTH_PROXY_URL=http://localhost:10000
